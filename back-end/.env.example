# Copy to .env and set your MySQL password:
#   cp .env.example .env

JWT_SECRET=wasl-secret-2026
DB_HOST=localhost
DB_USER=root
DB_PASS=your-mysql-password-here
DB_NAME=wasl_db

# Email — required for donor match alerts (blood type + city)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=wasl <your-email@gmail.com>
