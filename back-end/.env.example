# Copy to .env and set your MySQL password:
#   cp .env.example .env
#
# Default admin (created by db.sql / app startup):
#   Email: admin@wasl.com
#   Password: admin123

JWT_SECRET=wasl-secret-2026
DB_HOST=localhost
DB_USER=root
DB_PASS=NewStrongPass123!
DB_NAME=wasl_db

# Email — required for donor match alerts (blood type + city)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=wasl <your-email@gmail.com>
